# Get this from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: OpenRouter key for MiniMax fallback
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: switch bone inference to ML
BONE_MODEL_MODE=gemini

# Optional: override model root
# MODEL_ROOT=

# Optional: override modality classifier
# MODALITY_MODEL_PATH=model_files/modality_model.h5
